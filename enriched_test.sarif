      {
        "control_id": "AC-3",
        "framework": "NIST SP 800-53",
        "relevance_score": 0.95,
        "citation": "This finding relates to access enforcement, specifically ensuring that public access to S3 buckets is blocked, aligning with the control's objective of controlling access to organizational information systems."
      }
    ],
