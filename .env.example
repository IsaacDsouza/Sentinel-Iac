# Database
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel

# LLM (OpenAI-compatible — NVIDIA NIM free tier shown)
OPENAI_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=meta/llama-3.3-70b-instruct

# Embeddings (local sentence-transformers, no key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# API auth (empty = no auth required)
API_KEY=

# Logging
LOG_LEVEL=INFO
